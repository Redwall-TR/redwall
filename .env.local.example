# Yerel geliştirme ortam değişkenleri (ŞABLON) — `cp .env.local.example .env.local`
NEXT_PUBLIC_SITE_URL=https://redwall.tr

# Payload CMS — yerel Postgres + MinIO (docker compose -f deploy/compose.dev.yml up -d)
PAYLOAD_SECRET=dev-secret-change-me-0123456789
DATABASE_URI=postgres://redwall:redwall@127.0.0.1:5433/redwall
S3_BUCKET=redwall-media
S3_REGION=us-east-1
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
