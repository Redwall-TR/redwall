# GlitchTip ops kurulumu — kopyalayıp .env yapın, doldurun
GLITCHTIP_SECRET_KEY=uzun-rastgele-secret-uret-openssl-rand-hex-32
GLITCHTIP_DB_PASSWORD=guclu-bir-parola
GLITCHTIP_DOMAIN=https://hata.redwall.tr
GLITCHTIP_FROM_EMAIL=glitchtip@redwall.tr

# Kayıt/SSO ayrımı (bkz. docker-compose.yml yorumu) — varsayılanlar zaten güvenli, elle
# değiştirmek istemedikçe bu üçünü .env'e eklemene gerek yok:
# GLITCHTIP_OPEN_REGISTRATION=false   # yeni kayıt olan kendi organizasyonunu oluşturamaz
# GLITCHTIP_USER_REGISTRATION=false   # e-posta/parola ile doğrudan kayıt kapalı
# GLITCHTIP_SSO_REGISTRATION=true     # Authentik SSO ile ilk girişte hesap otomatik açılır
#
# Authentik OIDC SocialApp'i (client_id/secret) env ile YAPILANDIRILAMIYOR — GlitchTip 6.2.0
# kaynağında (glitchtip/settings.py) generic OIDC provider'ı için SOCIALACCOUNT_PROVIDERS/env yolu
# yok; yalnız DB'deki SocialApp kaydı üzerinden çalışıyor. Kurulum komutu: README.md → "SSO (Authentik OIDC)".
