# Redwall monitör ajanı — hedef sunucu ortam değişkenleri.
# Kullanım: cp .env.example .env → doldur. .env COMMIT EDİLMEZ.

# Bu hedefin adı (Grafana'da 'host' etiketi olur): erp | yp-test | yp-self | license | kurumsal
AGENT_HOSTNAME=degistir

# Metrik remote-write ucu (monitör Prometheus, Traefik+basic-auth arkası)
PROM_URL=https://push.redwall.tr/api/v1/write
PROM_USER=agent
PROM_PASS=degistir-prom-parola

# Log push ucu (monitör Loki)
LOKI_URL=https://loki.redwall.tr/loki/api/v1/push
LOKI_USER=agent
LOKI_PASS=degistir-loki-parola
