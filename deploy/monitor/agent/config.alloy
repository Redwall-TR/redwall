// Redwall monitör ajanı (Grafana Alloy) — her hedef sunucuda tek container.
// Host metriği (unix) + container metriği (cadvisor) + docker logları → monitör'e PUSH
// (HTTPS + basic-auth, hepsi OUTBOUND). Hedefte inbound port açılmaz, salt-okuma.

// ════════ METRİKLER ════════
// Host: CPU/RAM/disk/ağ (node_exporter eşdeğeri, Alloy içi)
prometheus.exporter.unix "node" {
  rootfs_path = "/host/root"
  procfs_path = "/host/proc"
  sysfs_path  = "/host/sys"
  filesystem {
    mount_points_exclude = "^/(dev|proc|sys|var/lib/docker/.+|run)($|/)"
    fs_types_exclude     = "^(autofs|binfmt_misc|bpf|cgroup2?|configfs|debugfs|devpts|devtmpfs|fusectl|hugetlbfs|mqueue|nsfs|overlay|proc|procfs|pstore|securityfs|selinuxfs|squashfs|sysfs|tracefs)$"
  }
}

// Container: docker/swarm container başına kaynak (cadvisor, Alloy içi)
// disabled_metrics: Alloy varsayılanına (advtcp/cpu_topology/cpuset/hugetlb/memory_numa/
// process/referenced_memory/resctrl/tcp/udp) "disk"+"diskIO" EKLENDİ (2026-07-11, T3-11b
// kök-çözüm — bkz. self-agent/config.alloy). Sebep: cadvisor'un per-container inode/disk
// kullanımı için stat ettiği /var/lib/docker/rootfs/overlayfs/<id> yolu, kısa-ömürlü
// `docker run --rm` konteynerleri taranırken konteyner zaten kaldırılmış oluyor →
// kalıcı "rootDiskErr" gürültüsü (monitör kutusunda gözlendi). disk/diskIO ailesi repo'daki
// hiçbir dashboard/SLO/alert tarafından kullanılmıyor — container CPU/RAM/ağ metrikleri
// etkilenmez. Bu değişiklik ŞABLONDA; canlı 5 hedef ajanda sorun GÖZLENMEDİĞİ için (2026-07-11
// kontrol) canlı config'lere dokunulmadı — bir sonraki redeploy'da otomatik gelir.
prometheus.exporter.cadvisor "cadvisor" {
  docker_host      = "unix:///var/run/docker.sock"
  storage_duration = "5m"
  disabled_metrics = [
    "advtcp", "cpu_topology", "cpuset", "disk", "diskIO", "hugetlb",
    "memory_numa", "process", "referenced_memory", "resctrl", "tcp", "udp",
  ]
}

// instance etiketini okunur sunucu adına sabitle (yoksa Alloy container'ının rastgele
// hostname'i gelir → dashboard'larda "jq1w9fmlvf" gibi görünür).
discovery.relabel "node" {
  targets = prometheus.exporter.unix.node.targets
  rule {
    target_label = "instance"
    replacement  = sys.env("AGENT_HOSTNAME")
  }
}

discovery.relabel "cadvisor" {
  targets = prometheus.exporter.cadvisor.cadvisor.targets
  rule {
    target_label = "instance"
    replacement  = sys.env("AGENT_HOSTNAME")
  }
}

prometheus.scrape "node" {
  targets         = discovery.relabel.node.output
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "node"
}

prometheus.scrape "cadvisor" {
  targets         = discovery.relabel.cadvisor.output
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "cadvisor"
}

prometheus.remote_write "monitor" {
  endpoint {
    url = sys.env("PROM_URL")
    basic_auth {
      username = sys.env("PROM_USER")
      password = sys.env("PROM_PASS")
    }
  }
  external_labels = {
    host = sys.env("AGENT_HOSTNAME"),
  }
}

// ════════ ALLOY ÖZ-METRİKLERİ (T6b: LogAkisiKesildi alarmı için loki_write_* şart) ════════
// Alloy kendi iç metriklerini (component sağlığı, loki.write yazma durumu) varsayılan olarak
// Prometheus'a GÖNDERMEZ — yalnız kendi :12345/metrics ucunda durur. prometheus.exporter.self
// bu ucu bir "target" olarak açar; yerel prometheus.scrape ile kazınıp mevcut remote-write
// zincirine katılır. KARDİNALİTE: yalnız loki_write_* ailesi + alloy_build_info tutulur
// (prometheus.relabel keep) — Alloy'un tüm dahili metrikleri (go_*, process_*, vb.) atılır.
prometheus.exporter.self "alloy" { }

discovery.relabel "alloy_self" {
  targets = prometheus.exporter.self.alloy.targets
  rule {
    target_label = "instance"
    replacement  = sys.env("AGENT_HOSTNAME")
  }
}

prometheus.scrape "alloy_self" {
  targets         = discovery.relabel.alloy_self.output
  forward_to      = [prometheus.relabel.alloy_self.receiver]
  scrape_interval = "30s"
  job_name        = "alloy"
}

prometheus.relabel "alloy_self" {
  forward_to = [prometheus.remote_write.monitor.receiver]
  rule {
    source_labels = ["__name__"]
    regex         = "loki_write_.*|alloy_build_info"
    action        = "keep"
  }
}

// ════════ UYGULAMA/DB EXPORTER'LARI (ayrı servisler, köprü ağı üzerinden scrape) ════════
// Exporter'lar traefik-public (attachable) ağında; Alloy o ağa katılıp servis-DNS'iyle kazır.
// Her *_ADDR env'i o sunucuda ilgili exporter varsa doldurulur; YOKSA ilgili blok o sunucuya
// deploy edilen config'den ÇIKARILIR (rollout'ta sunucu-bazlı). instance=sunucu adı sabit.

prometheus.scrape "traefik" {
  targets         = [{ "__address__" = sys.env("TRAEFIK_METRICS_ADDR"), "instance" = sys.env("AGENT_HOSTNAME") }]
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "traefik"
}

prometheus.scrape "postgres" {
  targets         = [{ "__address__" = sys.env("PG_EXPORTER_ADDR"), "instance" = sys.env("AGENT_HOSTNAME") }]
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "postgres"
}

prometheus.scrape "redis" {
  targets         = [{ "__address__" = sys.env("REDIS_EXPORTER_ADDR"), "instance" = sys.env("AGENT_HOSTNAME") }]
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "redis"
}

prometheus.scrape "mysql" {
  targets         = [{ "__address__" = sys.env("MYSQL_EXPORTER_ADDR"), "instance" = sys.env("AGENT_HOSTNAME") }]
  forward_to      = [prometheus.remote_write.monitor.receiver]
  scrape_interval = "30s"
  job_name        = "mysql"
}

// ════════ LOGLAR ════════
// Tüm docker container loglarını keşfet + tail → monitör Loki
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
  targets = discovery.docker.containers.targets
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }
  rule {
    source_labels = ["__meta_docker_container_log_stream"]
    target_label  = "stream"
  }
}

// ════════ GÜRÜLTÜ SÜZGECİ (2026-07-10, kullanıcı ilkesi: yalnız gerçek sinyal) ════════
// 1) fpm self-healthcheck yankısı: container kendi kendine 127.0.0.1 GET /index.php 200
//    — sıfır bilgi değeri. DİKKAT: yalnız " 200" düşer; healthcheck BAŞARISIZLIĞI (5xx) Loki'ye gider.
// 2) Frappe rq worker gevezeliği (ERP): "Result is kept for N seconds".
// 3) Traefik access-log'unda Alloy'un kendi /metrics scrape yankısı (prometheus@internal,
//    30s'de bir 200) — scrape sağlığı zaten Prometheus `up` metriğinde; yalnız 200 düşer,
//    scrape HATASI (4xx/5xx) Loki'ye gider.
loki.process "gurultu" {
  forward_to = [loki.write.monitor.receiver]
  stage.drop {
    expression = "^127\\.0\\.0\\.1 .*\"GET /index\\.php\" 200"
  }
  stage.drop {
    expression = "Result is kept for [0-9]+ seconds"
  }
  stage.drop {
    expression = "\"GET /metrics HTTP/[0-9.]+\" 200 .*\"prometheus@internal\""
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.gurultu.receiver]
  labels     = {
    host = sys.env("AGENT_HOSTNAME"),
    job  = "docker",
  }
}

loki.write "monitor" {
  endpoint {
    url = sys.env("LOKI_URL")
    basic_auth {
      username = sys.env("LOKI_USER")
      password = sys.env("LOKI_PASS")
    }
  }
}
