# Monitör kutusunun öz-ajanı — ortam değişkenleri.
# Kullanım: cp .env.example .env (sunucuda). .env COMMIT EDİLMEZ.
# Hedef-ajanlardan (deploy/monitor/agent/.env.example) FARK: bu değerler değişmez/sabit —
# tek kutu, iç ağ, basic-auth yok. Yine de env üzerinden geçilir (config.alloy tutarlılığı).

# Bu kutunun adı (Grafana'da 'host'/'instance' etiketi). DEĞİŞTİRME.
AGENT_HOSTNAME=redwall-monitor

# Metrik remote-write ucu — İÇ ağ, monitör kutusunun kendi Prometheus'u (basic-auth YOK).
PROM_URL=http://prometheus:9090/api/v1/write

# Log push ucu — İÇ ağ, monitör kutusunun kendi Loki'si (basic-auth YOK).
LOKI_URL=http://loki:3100/loki/api/v1/push
