# Redwall — deploy ortam değişkenleri (ŞABLON)
# Bu dosya dokümantasyondur. Gerçek değerler CI'da GitHub Secrets/Variables'tan
# gelir ve `docker stack deploy` öncesi sunucuda export edilir.
# Manuel deploy için: `cp .env.example .env && set -a && . ./.env && set +a`

# ── Build zamanı (NEXT_PUBLIC_*, GitHub *Variables*) ───────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=22ukr7s6
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
NEXT_PUBLIC_SITE_URL=https://redwall.tr

# ── stack.yml interpolasyonu (deploy zamanı) ───────────────────────────────
# Docker Hub kullanıcı adınız/imaj:tag. CI bunu sha ile doldurur.
WEB_IMAGE=docker.io/<DOCKERHUB_USERNAME>/redwall-web:latest
SITE_HOST=redwall.tr
ACME_EMAIL=info@redwall.tr

# ── Sunucu-yalnızı sırlar (GitHub *Secrets*) ───────────────────────────────
SANITY_API_READ_TOKEN=<sanity-read-token>
# Not: TLS, Cloudflare "Full" + Traefik self-signed cert ile sağlanır → ACME/CF token gerekmez.

# ── Faz 2 (Payload) — ileride ──────────────────────────────────────────────
# PAYLOAD_SECRET=<rastgele-32+ karakter>
# DATABASE_URI=postgres://redwall:<pass>@postgres:5432/redwall
# MINIO_ROOT_USER=<minio-user>
# MINIO_ROOT_PASSWORD=<minio-pass>
